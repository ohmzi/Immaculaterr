# =============================================================================
# Immaculaterr Docker — Environment Variables
# Copy this file to .env and adjust values for your deployment.
# =============================================================================

# --- Master Encryption Key ---
# 32-byte key (64-char hex or base64). Auto-generated if unset.
# APP_MASTER_KEY=
# Or mount a Docker secret and reference its path:
# APP_MASTER_KEY_FILE=/run/secrets/app_master_key

# --- File Permissions ---
# Umask for files created inside the container (default: 0022)
# APP_UMASK=0022

# --- Ports ---
# Host port for the web UI
# WEB_PORT=5858
# Host port for the API
# API_PORT=5454

# --- Caddy / TLS ---
# CADDY_TLS=internal
# CADDY_DOMAIN=localhost

# --- Plex Webhook ---
# Auto-generated to data dir if unset. Retrieve via GET /api/webhooks/secret.
# PLEX_WEBHOOK_SECRET=

# --- Reverse Proxy ---
# TRUST_PROXY=1

# --- CORS ---
# CORS_ORIGINS=
