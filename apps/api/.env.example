# =============================================================================
# Immaculaterr API — Environment Variables
# Copy this file to .env and adjust values for your deployment.
# =============================================================================

# --- Data & Database ---
# Directory for persisted data (keys, webhook events, etc.)
# APP_DATA_DIR=/path/to/data

# SQLite database connection URL
# DATABASE_URL=file:/path/to/data/immaculaterr.db

# --- Master Encryption Key ---
# 32-byte key (64-char hex or base64). Auto-generated to APP_DATA_DIR/app-master.key if unset.
# APP_MASTER_KEY=
# Or point to a file containing the key:
# APP_MASTER_KEY_FILE=/run/secrets/app_master_key

# --- Credential Envelope ---
# RSA private key (PEM or base64-encoded PEM). Auto-generated to APP_DATA_DIR/credential-envelope.pem if unset.
# AUTH_CREDENTIALS_PRIVATE_KEY=
# Max clock skew (ms) allowed for credential envelope timestamps (default: 300000 = 5 min)
# AUTH_CREDENTIAL_ENVELOPE_MAX_SKEW_MS=300000

# --- Webhook Secret ---
# Plex webhook authentication secret. Auto-generated to APP_DATA_DIR/webhook-secret if unset.
# Retrieve the auto-generated value via GET /api/webhooks/secret.
# PLEX_WEBHOOK_SECRET=

# --- Session & Cookies ---
# Set to "true" when serving behind HTTPS to mark session cookies as Secure.
# COOKIE_SECURE=false
# Session max age in milliseconds (default: 7 days)
# SESSION_MAX_AGE_MS=604800000

# --- CORS ---
# Comma-separated list of allowed origins (e.g. https://myapp.example.com).
# Leave empty for same-origin only in production.
# CORS_ORIGINS=

# --- Reverse Proxy ---
# Express "trust proxy" setting. Use "1" behind a single reverse proxy,
# "loopback" for localhost proxies, or a CIDR like "172.16.0.0/12".
# TRUST_PROXY=1

# --- Rate Limiting ---
# Global API rate limit (per IP)
# API_RATE_LIMIT_MAX=120
# API_RATE_LIMIT_WINDOW_MS=60000

# Auth endpoint rate limits (per IP)
# AUTH_RATE_LIMIT_WINDOW_MS=60000
# AUTH_RATE_LIMIT_MAX_LOGIN=10
# AUTH_RATE_LIMIT_MAX_REGISTER=3
# AUTH_RATE_LIMIT_MAX_GET=20

# Webhook rate limit (per IP)
# WEBHOOK_RATE_LIMIT_MAX=30
# WEBHOOK_RATE_LIMIT_WINDOW_MS=60000

# --- Auth Lockout (brute-force protection) ---
# AUTH_LOCKOUT_WINDOW_MS=900000
# AUTH_LOCKOUT_THRESHOLD=5
# AUTH_LOCKOUT_MS=900000
# AUTH_LOCKOUT_MAX_MS=43200000

# --- Argon2 Tuning ---
# ARGON2_TIME_COST=3
# ARGON2_MEMORY_COST=65536
# ARGON2_PARALLELISM=4

# --- CAPTCHA ---
# Set to "true" to enable CAPTCHA after repeated login failures.
# AUTH_CAPTCHA_ENABLED=false
# AUTH_CAPTCHA_VERIFY_URL=
# AUTH_CAPTCHA_AFTER_FAILURES=3

# --- Server ---
# PORT=5454
# HOST=0.0.0.0
# NODE_ENV=production

# --- Swagger ---
# Enable Swagger UI in production (disabled by default in production).
# SWAGGER_ENABLED=false

# --- HTTP Logging ---
# HTTP_LOGGING=false
# HTTP_SLOW_REQUEST_THRESHOLD_MS=1500
